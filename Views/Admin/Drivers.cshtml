@model IEnumerable<EVRP_Web.Models.Driver>

<div class="container mt-4">
    <h2><i class="fa fa-users"></i> Quản Lý Nhân Viên Giao Hàng</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Mã NV</th>
                <th>Họ và Tên</th>
                <th>Số Điện Thoại</th>
                <th>Xe Điện Đảm Nhận</th>
                <th>Trạng Thái</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var driver in Model)
            {
                <tr>
                    <td>@driver.Id</td>
                    <td>@driver.Name</td>
                    <td>@driver.Phone</td>
                    <td><span class="badge bg-info">@driver.VehicleLicense</span></td>
                    <td>@(driver.IsActive ? "Sẵn sàng" : "Đang giao hàng")</td>
                    <td>
                        <button class="btn btn-sm btn-warning">Sửa</button>
                        <button class="btn btn-sm btn-danger">Xóa</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>