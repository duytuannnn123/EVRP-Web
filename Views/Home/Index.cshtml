@using EVRP_Web.Models
@model List<EVRP_Web.Models.Customer>

@{
    ViewData["Title"] = "Báo Cáo Tổng Quan Hệ Thống Điều Phối Lộ Trình";
    var totalCustomers = ViewBag.TotalCustomers ?? 0;
    var totalDrivers = ViewBag.TotalDrivers ?? 0;
    var totalStations = ViewBag.TotalStations ?? 0;
    var totalDemand = ViewBag.TotalDemand ?? 0;
}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
        color: #1e293b;
    }

    .home-container {
        padding: 30px;
    }

    .welcome-banner {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        color: #ffffff;
        border-radius: 16px;
        padding: 40px;
        margin-bottom: 30px;
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.2);
    }

    .stat-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    }

    .icon-box {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .icon-blue { background-color: #eff6ff; color: #2563eb; }
    .icon-green { background-color: #f0fdf4; color: #16a34a; }
    .icon-red { background-color: #fef2f2; color: #dc2626; }
    .icon-purple { background-color: #faf5ff; color: #9333ea; }

    .quick-link-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 30px;
        text-align: center;
        height: 100%;
        transition: all 0.2s ease-in-out;
    }

    .quick-link-card:hover {
        border-color: #2563eb;
        background: #f8fafc;
    }

    .table-custom {
        width: 100%;
        margin-bottom: 0;
    }

    .table-custom th {
        background: #f8fafc;
        color: #475569;
        font-weight: 600;
        padding: 12px 16px;
        border-bottom: 2px solid #e2e8f0;
    }

    .table-custom td {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
</style>

<div class="container-fluid home-container text-start">
    
    <div class="welcome-banner">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="fw-bold mb-2">Hệ Thống Trung Tâm Điều Hành Logistics Thông Minh</h1>
                <p class="mb-0 opacity-90">Ứng dụng thuật toán tối ưu hóa ALNS giải quyết bài toán định tuyến xe tải điện phân phối hàng hóa đô thị xanh bền vững (EVRP).</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <span class="badge bg-white text-primary px-3 py-2 fw-bold rounded-pill"><i class="fas fa-shield-alt me-1"></i> Mode: Administrator</span>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase fw-bold mb-1">Đội Xe Sẵn Sàng</h6>
                    <h3 class="fw-bold text-dark m-0">@totalDrivers Xe</h3>
                </div>
                <div class="icon-box icon-blue">
                    <i class="fas fa-truck-moving"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase fw-bold mb-1">Tổng Số Khách Hàng</h6>
                    <h3 class="fw-bold text-dark m-0">@totalCustomers Điểm</h3>
                </div>
                <div class="icon-box icon-red">
                    <i class="fas fa-user-friends"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase fw-bold mb-1">Mạng Lưới Trạm Sạc</h6>
                    <h3 class="fw-bold text-dark m-0">@totalStations Trạm</h3>
                </div>
                <div class="icon-box icon-green">
                    <i class="fas fa-charging-station"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase fw-bold mb-1">Khối Lượng Cần Giao</h6>
                    <h3 class="fw-bold text-dark m-0">@totalDemand kg</h3>
                </div>
                <div class="icon-box icon-purple">
                    <i class="fas fa-weight-hanging"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="quick-link-card shadow-sm d-flex flex-column align-items-center justify-content-center">
                <div class="icon-box icon-blue mb-3" style="width: 70px; height: 70px; font-size: 32px;">
                    <i class="fas fa-route"></i>
                </div>
                <h4 class="fw-bold text-dark mb-2">1. Điều Phối Lộ Trình Xe Chạy</h4>
                <p class="text-muted small px-3">Kích hoạt thuật toán ALNS tính toán, vẽ đường OSRM tự động, giám sát lượng tiêu hao phần trăm pin trực quan chặng cuối trên bản đồ đô thị Vinh.</p>
                <a asp-controller="Admin" asp-action="Routing" class="btn btn-primary fw-bold px-4 py-2 mt-2 rounded-3">Truy Cập Bản Đồ Điều Tuyến <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="quick-link-card shadow-sm d-flex flex-column align-items-center justify-content-center">
                <div class="icon-box icon-green mb-3" style="width: 70px; height: 70px; font-size: 32px;">
                    <i class="fas fa-database"></i>
                </div>
                <h4 class="fw-bold text-dark mb-2">2. Quản Lý Cơ Sở Dữ Liệu Đối Tác</h4>
                <p class="text-muted small px-3">Cập nhật danh sách tài xế, trạm sạc tĩnh cố định, quản lý danh sách khách hàng nhận hàng hóa, tích hợp tính năng ghim chuột trên map tự điền GPS.</p>
                <a asp-controller="Admin" asp-action="Management" class="btn btn-success fw-bold px-4 py-2 mt-2 rounded-3">Truy Cập Danh Mục Đối Tác <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
        <div class="card-header bg-white py-3 fw-bold text-dark border-bottom"><i class="fas fa-history text-secondary me-2"></i>Danh Sách Khách Hàng Mới Cập Nhật</div>
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle">
                <thead>
                    <tr>
                        <th>Tên cửa hàng / Khách hàng</th>
                        <th>Địa chỉ bàn giao</th>
                        <th>Tọa độ GPS (Vĩ độ | Kinh độ)</th>
                        <th>Khối lượng đơn (kg)</th>
                        <th>Khung giờ nhận hàng</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark"><i class="fas fa-store me-2 text-muted"></i>@c.Name</td>
                                <td class="small text-secondary">@c.Address</td>
                                <td><code>@c.Latitude.ToString("0.0000") | @c.Longitude.ToString("0.0000")</code></td>
                                <td><span class="badge bg-warning text-dark fw-bold">@c.Demand kg</span></td>
                                <td class="small font-monospace">@c.TimeWindow</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu khách hàng nào trong bảng Customers của MySQL.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>